# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Authorized Telegram User IDs (from @userinfobot)
# To allow multiple users, separate IDs with commas — NO spaces
# Example single user:  TELEGRAM_USER_IDS=123456789
# Example multi  user:  TELEGRAM_USER_IDS=123456789,987654321,555000111
TELEGRAM_USER_IDS=your_telegram_user_id_here

# Google Gemini API Key (from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Path to YouTube OAuth2 client secret JSON file (default: client_secret.json)
YOUTUBE_CLIENT_SECRET_FILE=client_secret.json
